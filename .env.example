# =============================================================
# Instagram Meme Bot – Configuration
# Copy to .env and fill in your values
# =============================================================

# ---- Instagram Credentials (REQUIRED) -----------------------
INSTA_USERNAME=your_instagram_username
INSTA_PASSWORD=your_instagram_password

# ---- Scheduling ---------------------------------------------
POSTS_PER_DAY=3
ACTIVE_HOURS_START=9
ACTIVE_HOURS_END=23
TIMEZONE=Asia/Kolkata

# ---- Post Types (comma-separated) ---------------------------
# Available: funny, hinglish, trending, desi, relatable, programming
POST_TYPES=funny,hinglish,trending

# ---- Rate Limiting & Safety ---------------------------------
MAX_POSTS_PER_DAY=5
MIN_POST_INTERVAL_MIN=30
MAX_POST_INTERVAL_MIN=120
WARM_UP_DAYS=7
SAFE_MODE_HOURS=6
ENABLE_WEEKEND_PAUSE=false
WEEKEND_MAX_POSTS=2

# ---- GUI Dashboard ------------------------------------------
GUI_ENABLED=true
GUI_PORT=3000

# ---- Keep-Alive (Render / Free Hosts) -----------------------
# Set this to your Render external URL to keep the server alive
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
KEEP_ALIVE_INTERVAL=10

